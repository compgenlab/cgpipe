{
  "name": "cgp",
  "displayName": "cgp",
  "description": "Language support for cgp pipeline scripts (syntax highlighting + language server).",
  "version": "0.1.0",
  "publisher": "compgen-io",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/compgen-io/cgp"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:cgp"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cgp",
        "aliases": [
          "cgp",
          "CGP"
        ],
        "extensions": [
          ".cgp",
          ".cgp2"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cgp",
        "scopeName": "source.cgp",
        "path": "./syntaxes/cgp.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.shell.cgp": "shellscript"
        }
      }
    ],
    "configuration": {
      "title": "cgp",
      "properties": {
        "cgp.serverPath": {
          "type": "string",
          "default": "cgp",
          "markdownDescription": "Path to the `cgp` binary used to run the language server (`cgp lsp`). Defaults to `cgp` on your PATH."
        },
        "cgp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the communication between VSCode and the cgp language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run compile -- --sourcemap --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
