{
  "name": "cgpipe",
  "displayName": "cgpipe",
  "description": "Language support for cgpipe pipeline scripts (syntax highlighting + language server).",
  "version": "0.1.0",
  "publisher": "compgenlab",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/compgenlab/cgpipe"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:cgpipe"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cgpipe",
        "aliases": [
          "cgpipe",
          "CGPIPE"
        ],
        "extensions": [
          ".cgp",
          ".cgp2"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cgpipe",
        "scopeName": "source.cgp",
        "path": "./syntaxes/cgpipe.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.shell.cgp": "shellscript"
        }
      }
    ],
    "configuration": {
      "title": "cgpipe",
      "properties": {
        "cgpipe.serverPath": {
          "type": "string",
          "default": "cgpipe",
          "markdownDescription": "Path to the `cgp` binary used to run the language server (`cgp lsp`). Defaults to `cgp` on your PATH."
        },
        "cgpipe.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the communication between VSCode and the cgpipe language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run compile -- --sourcemap --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
