#!/usr/bin/env cgp
#
# One wildcard rule compresses every input file; `all` requests them together.
# Swap `gzip` for any per-file tool (samtools index, fastqc, …) and the shape
# is identical.
#
# Run:  cgp pipeline.cgp | bash

%.txt.gz: %.txt {{
    gzip -c ${input} > ${output}
}}

all: data/a.txt.gz data/b.txt.gz data/c.txt.gz
@default: all
