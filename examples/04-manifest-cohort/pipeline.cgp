#!/usr/bin/env cgp
#
# A single-sample pipeline. Run it across a whole cohort with a manifest:
#
#     cgp pipeline.cgp -manifest-tsv samples.tsv | bash
#
# Each row of samples.tsv (columns: sample, input) becomes one run, with the
# columns available as ${sample} and ${input}.

${sample}.sum: ${input} {{
    job.name = "sum-${sample}"
    --
    tr ' ' '\n' < ${input} | awk '{s += $1} END {print "${sample}:", s}' > ${output}
}}
@default: ${sample}.sum
