#!/bin/bash
# Mock BatchQ multi-tool. cgpipe invokes `batchq submit` (script on stdin),
# `batchq status <id>`, and `batchq release <id>`.
MOCK_NAME=batchq
. "$(dirname "$0")/../lib.sh"
case "${1:-}" in
    submit)
        capture_call submit "$@"
        next_jobid
        echo
        ;;
    status)
        capture_call status "$@"
        # Supports `status <id>` and `status --porcelain <id>`. A canned response
        # (or, absent CGP_TEST_RESPONSES, the default) reports the job active.
        id="${2:-}"; porc=
        [ "${2:-}" = --porcelain ] && { porc=1; id="${3:-}"; }
        if out=$(serve_response batchq "$id"); then
            [ -n "$out" ] || out=PROXYQUEUED
            if [ -n "$porc" ]; then printf '%s\t%s\n' "$id" "$out"; else echo "$id $out"; fi
            exit 0
        fi
        exit 1
        ;;
    release)
        capture_call release "$@"
        exit 0
        ;;
    *)
        echo "mock-batchq: unknown subcommand: ${1:-}" >&2
        exit 2
        ;;
esac
