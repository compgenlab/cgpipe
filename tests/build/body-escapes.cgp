# A {{ }} body is raw shell, NOT a cgpipe string literal: only \$ and \@ are special
# (they suppress ${…}/@{…}/$(…)). Every other backslash is shell text, verbatim.
host = "node1"
out.txt: {{
    echo "x\"y"
    echo back \\ slash
    echo "${host} \${HOME} $HOME"
    echo deferred \$(date)
    printf "tab=\t newline=\n"
}}
@default: out.txt
