#!/usr/bin/env bash
set -euo pipefail

# ---- out.bam ----
__cgpipe_body=$(mktemp "/tmp/cgpipe-body.XXXXXX")
trap 'rm -f "$__cgpipe_body"' EXIT
cat > "$__cgpipe_body" <<'__CGPIPE_BODY__'
samtools sort in.bam > out.bam
__CGPIPE_BODY__

docker run --rm \
    -v /tmp:/tmp \
    -v __WORKDIR__:__WORKDIR__ \
    -w __WORKDIR__ \
    -u $(id -u):$(id -g) \
    biocontainers/samtools:1.9 \
    sh "$__cgpipe_body"


