# §12 Per-target container settings shape the engine invocation: extra binds,
# env passthrough, raw opts, the in-image shell.
cgp.container.engine = "docker"
out.bam: in.bam {{
    job.container          = "img:1"
    job.container.bind     = ["/data", "/refs"]
    job.container.env      = ["SAMPLE"]
    job.container.opts     = ["--shm-size=1g"]
    job.container.shell    = "bash"
    --
    run ${input} > ${output}
}}
@default: out.bam
