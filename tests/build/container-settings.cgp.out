#!/usr/bin/env bash
set -euo pipefail

# ---- out.bam ----
__cgpipe_body=$(mktemp "/tmp/cgpipe-body.XXXXXX")
trap 'rm -f "$__cgpipe_body"' EXIT
cat > "$__cgpipe_body" <<'__CGPIPE_BODY__'
run in.bam > out.bam
__CGPIPE_BODY__

docker run --rm \
    -v /tmp:/tmp \
    -v __WORKDIR__:__WORKDIR__ \
    -v /data:/data \
    -v /refs:/refs \
    -w __WORKDIR__ \
    -u $(id -u):$(id -g) \
    -e SAMPLE \
    --shm-size=1g \
    img:1 \
    bash "$__cgpipe_body"


