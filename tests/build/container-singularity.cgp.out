#!/usr/bin/env bash
set -euo pipefail

# ---- out.bam ----
__cgpipe_body=$(mktemp "/tmp/cgpipe-body.XXXXXX")
trap 'rm -f "$__cgpipe_body"' EXIT
cat > "$__cgpipe_body" <<'__CGPIPE_BODY__'
bwa in.bam > out.bam
__CGPIPE_BODY__

singularity exec \
    -B /tmp:/tmp \
    -B __WORKDIR__:__WORKDIR__ \
    --pwd __WORKDIR__ \
    --nv \
    docker://biocontainers/bwa:0.7.17 \
    sh "$__cgpipe_body"


