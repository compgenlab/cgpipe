# §6.2 A directive block (before --) sets per-job settings in cgp mode; the
# shell template after -- may read them. Directive assignments don't emit shell.
threads = 8
out.txt: in.txt {{
    procs = threads
    mem   = "16G"
    --
    sort --parallel=${procs} ${input} > ${output}
}}
@default: out.txt
