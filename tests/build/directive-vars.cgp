# §6.2 A directive block (before --) sets per-job settings in cgpipe mode; the
# shell template after -- may read them. Directive assignments don't emit shell.
threads = 8
out.txt: in.txt {{
    job.procs = threads
    job.mem   = "16G"
    --
    sort --parallel=${job.procs} ${input} > ${output}
}}
@default: out.txt
