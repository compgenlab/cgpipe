# A cgp string literal is one escape domain: its escapes (incl. \") are resolved
# before the ${...} interior is parsed, so a nested string argument works.
name = "reads.bam"
print "stem=${name.sub(\".bam\", \"\")}"            # stem=reads
print "${if name; \"have:\" + name; \"none\"}"      # have:reads.bam
exit
