#!/bin/bash
#BATCHQ -name merged.vcf
#BATCHQ -afterok 1001_1,1001_2,1001_3
#BATCHQ -input calls.chr1.vcf
#BATCHQ -input calls.chr2.vcf
#BATCHQ -input calls.chr3.vcf
#BATCHQ -output merged.vcf
#BATCHQ -wd .

set -eo pipefail


bcftools concat calls.chr1.vcf calls.chr2.vcf calls.chr3.vcf > merged.vcf

