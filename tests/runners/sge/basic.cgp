# Submit one job with per-job directives; each scheduler translates name/mem/
# procs/walltime into its own header lines, and cgp prints the assigned job id.
out.bam: {{
    job.name     = "align"
    job.mem      = "8G"
    job.procs    = 4
    job.walltime = "12:00:00"
    --
    echo aligning > ${output}
}}
@default: out.bam
