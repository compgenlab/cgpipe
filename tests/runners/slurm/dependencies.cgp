# A downstream job carries the upstream job id in the scheduler's dependency
# directive. a.bam submits first (1001); b.bam second (1002, afterok:1001).
b.bam: a.bam {{
    name = "post"
    --
    cp ${input} ${output}
}}
a.bam: {{
    name = "align"
    --
    echo a > ${output}
}}
@default: b.bam
