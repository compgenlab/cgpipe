# A multi-output upstream feeds two inputs to one downstream job; the duplicate
# afterok dependency on the single producer is collapsed (afterok:1001, once).
a.bam a.bai: {{
    job.name = "align"
    --
    echo a > a.bam; echo i > a.bai
}}
merged.bam: a.bam a.bai {{
    job.name = "merge"
    --
    cat ${input} > ${output}
}}
@default: merged.bam
