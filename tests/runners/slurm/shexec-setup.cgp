# §8 An @setup with shexec runs locally on the submit host (no sbatch); the
# normal target is still submitted. The shexec echo appears on stdout.
@setup {{
    job.shexec = true
    --
    echo "setup ran on submit host"
}}
out.bam: {{
    job.name = "j"
    --
    echo x > ${output}
}}
@default: out.bam
